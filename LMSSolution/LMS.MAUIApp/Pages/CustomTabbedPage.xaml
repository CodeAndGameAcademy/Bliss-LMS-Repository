<?xml version="1.0" encoding="utf-8" ?>
<TabbedPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            x:Class="LMS.MAUIApp.Pages.CustomTabbedPage"
            xmlns:local="clr-namespace:LMS.MAUIApp.Pages"
            xmlns:android="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.AndroidSpecific;assembly=Microsoft.Maui.Controls"
            android:TabbedPage.ToolbarPlacement="Bottom"
            BarBackgroundColor="#D8E0E6"
            BackgroundColor="{StaticResource PrimaryBackgroundColor}">

    <NavigationPage Title="Home" IconImageSource="home.png" BarBackgroundColor="{StaticResource PrimaryColor}" BarTextColor="{StaticResource SecondaryColor}">
        <x:Arguments>
            <local:HomePage/>
        </x:Arguments>
    </NavigationPage>
    <local:MyCoursesPage Title="My Courses" IconImageSource="mycourse.png" />
    <local:ProfilePage Title="Profile" IconImageSource="profile.png" />

</TabbedPage>