<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LMS.MAUIApp.Pages.SignInPage"             
             BackgroundColor="{DynamicResource PrimaryBackgroundColor}"
             NavigationPage.HasNavigationBar="False">

    <ScrollView Padding="16">
        <Grid RowSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                <Label Text="Sign In" Style="{StaticResource HeadlineMedium}"  />
                <Label Text="Sign in with your registered mobile" Style="{StaticResource TitleSmall}"/>
                <Image Source="logo.png" Margin="0,30" HorizontalOptions="Center" WidthRequest="150" />

                <HorizontalStackLayout Spacing="2">
                    <Label Text="Mobile" Style="{StaticResource TitleSmall}"/>
                    <Label Text="*" Style="{StaticResource TitleSmall}" TextColor="{StaticResource ErrorColor}"/>
                </HorizontalStackLayout>
                <Entry x:Name="TxtMobile" Placeholder="Enter your mobile" BackgroundColor="Transparent" />

                <HorizontalStackLayout Spacing="2">
                    <Label Text="Password" Style="{StaticResource TitleSmall}"/>
                    <Label Text="*" Style="{StaticResource TitleSmall}" TextColor="{StaticResource ErrorColor}"/>
                </HorizontalStackLayout>
                <Entry x:Name="TxtPassword" IsPassword="True" Placeholder="Enter your password" BackgroundColor="Transparent" />

                <Label Text="Forgot Password?" HorizontalOptions="Fill" HorizontalTextAlignment="End">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLblPasswordTapped"/>
                    </Label.GestureRecognizers>
                </Label>

                <Button x:Name="BtnSignIn" Text="Sign In" Margin="0,12,0,0" Padding="8" Clicked="BtnSignIn_Clicked"></Button>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,12">
                    <Label Text="Don't have an account?" Style="{StaticResource BodyMedium}" VerticalOptions="Center"/>
                    <Label Text="Sign Up" Style="{StaticResource TitleSmall}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLblSignUpTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>

            <Label LineBreakMode="WordWrap" Grid.Row="1" Grid.Column="0" HorizontalOptions="Fill" HorizontalTextAlignment="Center" LineHeight="1.5">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="By signing up you agree to our " Style="{StaticResource BodyMedium}" />

                        <Span Text="Terms Of Service " Style="{StaticResource BodyMedium}"  TextColor="Blue">
                            <Span.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTermsTapped"/>
                            </Span.GestureRecognizers>
                        </Span>

                        <Span Text="and " Style="{StaticResource BodyMedium}" />

                        <Span Text="Privacy Policy" Style="{StaticResource BodyMedium}" TextColor="Blue">
                            <Span.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPrivacyTapped"/>
                            </Span.GestureRecognizers>
                        </Span>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

        </Grid>
    </ScrollView>

</ContentPage>