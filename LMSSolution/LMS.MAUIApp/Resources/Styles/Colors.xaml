<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- ========== BRAND COLORS ========== -->
    <Color x:Key="PrimaryColor">#5A5BB5</Color>
    <Color x:Key="SecondaryColor">#ffffff</Color>
    <Color x:Key="BorderColor">#D8E0E6</Color>
    <Color x:Key="ErrorColor">#DB3D26</Color>

    <!-- ========== BACKGROUND COLORS ========== -->
    <Color x:Key="PrimaryBackgroundColor">#F2F5F7</Color>
    <Color x:Key="SecondaryBackgroundColor">#FFFFFF</Color>

    <!-- ========== TEXT COLORS ========== -->
    <Color x:Key="PrimaryTextColor">#14181B</Color>
    <Color x:Key="SecondaryTextColor">#57636C</Color>

    
    <!-- ========== SEMANTIC COLORS ========== -->
    <Color x:Key="SuccessColor">#34A853</Color>
    <Color x:Key="WarningColor">#E29512</Color>
    <Color x:Key="InfoColor">#0186D8</Color>
    <Color x:Key="DarkColor">#000000</Color>
    

    <!-- ========== CUSTOM COLORS ========== -->    
    <Color x:Key="TextFieldBG">#EDF1F4</Color>
    <Color x:Key="BlackColor">#000000</Color>
    <Color x:Key="WhiteColor">#FFFFFF</Color>


</ResourceDictionary>