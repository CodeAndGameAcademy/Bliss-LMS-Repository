@model LMS.AdminPanel.ViewModels.CourseLanguage.UpdateCourseLanguageViewModel

@{
	ViewData["title"] = "Edit Course Language";
	ViewData["subTitle"] = "Edit Course Language";
}

<div class="row gy-4">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">Edit Course Language</h6>
            </div>
            <div class="card-body">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-danger-100 text-danger-600 border-danger-100 px-24 py-11 mb-16 fw-semibold text-lg radius-8 d-flex align-items-center justify-content-between" role="alert">
                </div>

                <form asp-action="Edit"
                      asp-controller="CourseLanguage"
                      asp-route-id="@ViewBag.CourseLanguageId"
                      method="post">

                    @Html.AntiForgeryToken()

                <div class="row gy-3">
                    <div class="col-12">
                        <label class="form-label">Course Language <span class="text-danger-600">*</span></label>
                        <input type="text" asp-for="CourseLanguageName" class="form-control">
                        <span asp-validation-for="CourseLanguageName" class="text-danger d-block"></span>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary-600">Update Course Language</button>
                            <a asp-action="Index" class="btn btn-danger">Cancel</a>
                    </div>
                </div>

                </form>
            </div>
        </div><!-- card end -->        
    </div>
    
</div>